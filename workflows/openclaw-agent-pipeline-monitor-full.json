        "contentType": "application/json",
        "body": "={{ JSON.stringify({text: `✅ Job Completed: ${$json.body.data.job_id || 'N/A'} by ${$json.body.data.agent || 'unknown'}`, attachments: [{color: '#36a64f', title: 'Job Completed', fields: [{title: 'Job ID', value: String($json.body.data.job_id || 'N/A')}, {title: 'Agent', value: String($json.body.data.agent || 'N/A')}, {title: 'Task', value: String($json.body.data.task_type || 'N/A')}]}]}) }}",
        "options": {}
      },
      "id": "http-post-slack",
      "name": "HTTP POST - Slack",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [480, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ {ok: true, received: true} }}",
        "options": {}
      },
      "id": "respond-ok",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [720, 300]
    }
  ],
  "connections": {
