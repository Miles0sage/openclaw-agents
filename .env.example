# OpenClaw Agents — Environment Configuration
# Copy this file to .env and fill in your API keys.
# At minimum, you need ONE LLM provider key.

# ── LLM Providers (at least one required) ──────────────────────────────
ANTHROPIC_API_KEY=         # Claude models (Opus, Sonnet, Haiku)
DEEPSEEK_API_KEY=          # Kimi / DeepSeek models (cheapest option)
GEMINI_API_KEY=            # Google Gemini (free tier available)
OPENROUTER_API_KEY=        # OpenRouter (access to 200+ models)
XAI_API_KEY=               # Grok models
MINIMAX_API_KEY=           # MiniMax M2.5 (205K context)

# ── Notifications (optional) ───────────────────────────────────────────
SLACK_BOT_TOKEN=           # Slack bot for notifications
SLACK_REPORT_CHANNEL=      # Channel ID for reports (e.g., C0AFE4QHKH7)
TELEGRAM_BOT_TOKEN=        # Telegram bot token
TELEGRAM_CHAT_ID=          # Telegram chat ID for alerts

# ── Storage (optional, falls back to local JSON files) ─────────────────
SUPABASE_URL=              # Supabase project URL
SUPABASE_SERVICE_KEY=      # Supabase service role key

# ── Research Tools (optional) ──────────────────────────────────────────
PERPLEXITY_API_KEY=        # Perplexity Sonar for deep research

# ── Server Config (required) ──────────────────────────────────────────
GATEWAY_AUTH_TOKEN=         # Auth token for admin API access (required)
OPENCLAW_PORT=8000         # Gateway HTTP port
OPENCLAW_DATA_DIR=./data   # Data directory for logs, reflections, etc.
OPENCLAW_RUNNER_ENABLED=0  # Set to 1 to enable autonomous job runner
