# OpenClaw Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your API keys.
# Do NOT commit actual .env file with real secrets.
#
#   cp .env.example .env
#   # Edit .env with your API keys
#   python gateway.py
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────
# REQUIRED: CORE API KEYS
# ──────────────────────────────────────────────────────────────────────────

# Claude API key (Anthropic) - get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Supabase project URL - sign up free at https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key (from Settings > API Keys > Service Role)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# ──────────────────────────────────────────────────────────────────────────
# RECOMMENDED: FALLBACK LLM CHAIN
# ──────────────────────────────────────────────────────────────────────────

# DeepSeek API key - for Kimi 2.5 (cheap, fast coding model)
# Get from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# MiniMax API key - for complex reasoning tasks
# Get from https://www.minimaxi.com/user-center/api-keys
MINIMAX_API_KEY=sk-cp-your-minimax-key-here

# Alibaba DashScope Bailian - fallback coding API with 9+ models
# Get from https://dashscope.console.aliyun.com/api-keys
BAILIAN_API_KEY=sk-sp-your-bailian-key-here

# Google Gemini - free tier available, used for research fallback
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyYour-gemini-api-key-here

# Perplexity API - for research synthesis
# Get from https://www.perplexity.ai/api
PERPLEXITY_API_KEY=pplx-your-perplexity-key-here

# ──────────────────────────────────────────────────────────────────────────
# OPTIONAL: INTEGRATIONS
# ──────────────────────────────────────────────────────────────────────────

# Telegram bot token (from @BotFather on Telegram)
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklmnOPqrstUVwxyzABCDEF

# Slack bot token (starts with xoxb-)
# SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# GitHub token (for repo operations)
# GITHUB_TOKEN=ghp_your-github-token-here

# OpenAI API (for GPT-4 fallback)
# OPENAI_API_KEY=sk-proj-your-openai-key-here

# ──────────────────────────────────────────────────────────────────────────
# ADVANCED: GATEWAY & DEPLOYMENT
# ──────────────────────────────────────────────────────────────────────────

# Gateway server port (default: 18789)
PORT=18789

# Log level (debug, info, warning, error)
LOG_LEVEL=info

# Environment mode (development, staging, production)
NODE_ENV=development

# Data directory (relative path is fine)
OPENCLAW_DATA_DIR=./data

# Auth token for API requests (generate: openssl rand -hex 32)
# GATEWAY_AUTH_TOKEN=your-secure-random-32-byte-hex-string-here

# ──────────────────────────────────────────────────────────────────────────
# ADVANCED: LOCAL DEVELOPMENT
# ──────────────────────────────────────────────────────────────────────────

# Ollama local LLM server (if running locally)
# OLLAMA_HOST=http://localhost:11434

# Debug mode (verbose logging)
# DEBUG=1

# Test mode (mock data, no real API calls)
# TEST_MODE=1

# Cost tracking (logs all cost events)
# COST_TRACKING=1

# ──────────────────────────────────────────────────────────────────────────
# ADVANCED: OPTIONAL MCP SERVERS
# ──────────────────────────────────────────────────────────────────────────

# If you're running additional Supabase projects for specific features
# RESTAURANT_SUPABASE_URL=https://restaurant-project-id.supabase.co
# RESTAURANT_SUPABASE_KEY=eyJ...

# BARBERSHOP_SUPABASE_URL=https://barbershop-project-id.supabase.co
# BARBERSHOP_SUPABASE_KEY=eyJ...

# ──────────────────────────────────────────────────────────────────────────
# ADVANCED: TRADING & MARKET APIs
# ──────────────────────────────────────────────────────────────────────────

# The Odds API - for sports betting odds
# ODDS_API_KEY=your-odds-api-key-here

# Kalshi API - for binary options trading
# KALSHI_API_KEY_ID=your-kalshi-api-key-id-here
# KALSHI_PRIVATE_KEY_PATH=./data/trading/kalshi_private.pem

# ──────────────────────────────────────────────────────────────────────────
# ADVANCED: REDIS & CACHING (OPTIONAL)
# ──────────────────────────────────────────────────────────────────────────

# Upstash Redis - optional performance profiler (free tier available)
# UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token-here

# ──────────────────────────────────────────────────────────────────────────
# GUIDE: GETTING STARTED
# ──────────────────────────────────────────────────────────────────────────
#
# 1. Get your API keys:
#    - Claude: https://console.anthropic.com/account/keys
#    - Supabase: https://supabase.com (free)
#    - DeepSeek: https://platform.deepseek.com/api_keys (highly recommended, cheap)
#    - MiniMax: https://www.minimaxi.com/user-center/api-keys (optional)
#    - Gemini: https://aistudio.google.com/apikey (free tier available)
#
# 2. Fill in ANTHROPIC_API_KEY, SUPABASE_URL, and SUPABASE_KEY as minimum.
#
# 3. For best results, also add DEEPSEEK_API_KEY and GEMINI_API_KEY.
#
# 4. All other keys are optional - they're used for advanced features.
#
# 5. Uncomment optional integrations only if you need them (Telegram, Slack, etc).
#
# 6. For production, use a secrets manager instead of .env file.
#    See CONTRIBUTING.md for deployment guidelines.
